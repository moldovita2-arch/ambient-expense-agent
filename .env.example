# ==============================================================================
# Ambient Expense Agent - Local Authentication Configuration
# ==============================================================================

# Option 1: Google Cloud Project (Vertex AI / Gemini Enterprise)
# Set to "True" to use Vertex AI. 
# Run `gcloud auth application-default login` to authenticate your terminal.
# GOOGLE_GENAI_USE_VERTEXAI=True
# GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Option 2: Google AI Studio (Gemini Developer API)
# Set GOOGLE_GENAI_USE_VERTEXAI to "False" and provide your Gemini API key.
# Obtain API keys from: https://aistudio.google.com/
GOOGLE_GENAI_USE_VERTEXAI=False
GEMINI_API_KEY=your_api_key_here
